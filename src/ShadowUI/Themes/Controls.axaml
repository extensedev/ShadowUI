        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Badge.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Card.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Separator.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Label.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/CheckBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ToggleSwitch.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Avatar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Skeleton.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Kbd.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Toggle.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/RadioButton.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Tabs.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Slider.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ComboBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ScrollBar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Menu.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Menubar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/TitleBar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Sidebar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Dialog.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Toast.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Alert.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Spinner.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Accordion.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Breadcrumb.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ToggleGroup.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ColorPicker.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/NavigationMenu.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/HoverCard.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Sheet.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Collapsible.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/SearchableComboBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/OtpInput.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/InputGroup.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ButtonGroup.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Field.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowCalendar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/DatePicker.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/CommandPalette.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowDataTable.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowPagination.axaml" />
