<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shadui="using:ShadowUI">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Window.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Button.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Badge.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Card.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Separator.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Label.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/CheckBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ToggleSwitch.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Avatar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Skeleton.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Kbd.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Toggle.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/RadioButton.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Tabs.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Slider.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ComboBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ScrollBar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ScrollViewer.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ListBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Menu.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Menubar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/TitleBar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Sidebar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Dialog.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Toast.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Alert.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Spinner.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Accordion.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Breadcrumb.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ToggleGroup.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/NumericUpDown.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ColorPicker.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/NavigationMenu.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/HoverCard.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Popover.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Sheet.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Collapsible.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/SearchableComboBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/MultiSelectComboBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/OtpInput.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/InputGroup.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ButtonGroup.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Toolbar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Field.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowCalendar.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/DatePicker.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/CommandPalette.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowDataTable.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowPagination.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Resizable.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Carousel.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/EmptyState.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ShadowItem.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/BarChart.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/LineChart.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/AreaChart.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/TextBox.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/Tooltip.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Controls/ProgressBar.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- ButtonGroup: corner rounding of the outer buttons; global class-based styles -->
  <Style Selector="Button.button-group-first:not(.button-group-last)">
    <Setter Property="CornerRadius" Value="8,0,0,8" />
  </Style>
  <Style Selector="Button.button-group-middle">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
  </Style>
  <Style Selector="Button.button-group-last:not(.button-group-first)">
    <Setter Property="CornerRadius" Value="0,8,8,0" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
  </Style>
  <Style Selector="Button.button-group-first.button-group-last">
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
  </Style>

  <!-- Toolbar: compact nested items; highlight matches the item height, not the whole bar -->
  <Style Selector="shadui|Toolbar Button">
    <Setter Property="Height" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="shadui|Toolbar ToggleButton">
    <Setter Property="Height" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="shadui|Toolbar shadui|ToggleGroupItem">
    <Setter Property="Height" Value="28" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="shadui|Toolbar Separator.vertical">
    <Setter Property="Height" Value="18" />
    <Setter Property="Margin" Value="2,0" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ShadowCalendar day buttons: created from code-behind, so they are styled globally
       (ControlTheme child styles cannot reach elements with TemplatedParent == null) -->
  <Style Selector="shadui|ShadowCalendar Button.calendar-day">
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusSm}" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-other-month">
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-today">
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-selected">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-selected:pointerover /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-range-start">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-range-start:pointerover /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-range-end">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-range-end:pointerover /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
  </Style>
  <Style Selector="shadui|ShadowCalendar Button.calendar-day-in-range">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimary20Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
  </Style>

  <!-- MultiSelectComboBox chips: created from code-behind, styled globally -->
  <Style Selector="shadui|MultiSelectComboBox Border.multiselect-chip">
    <Setter Property="Background" Value="{DynamicResource ShadowSecondaryBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusSm}" />
    <Setter Property="Padding" Value="8,3,4,3" />
  </Style>
  <Style Selector="shadui|MultiSelectComboBox Border.multiselect-chip TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource ShadowSecondaryForegroundBrush}" />
  </Style>
  <Style Selector="shadui|MultiSelectComboBox Button.chip-remove:pointerover /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
  </Style>

  <!-- Carousel dot indicators: created from code-behind, styled globally -->
  <Style Selector="shadui|Carousel StackPanel#PART_DotsPanel Ellipse">
    <Setter Property="Fill" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <Style Selector="shadui|Carousel StackPanel#PART_DotsPanel Ellipse.active">
    <Setter Property="Fill" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <StyleInclude Source="avares://ShadowUI/Themes/Controls/TabsLarge.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/TabsLegacy.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/Table.axaml" />
</Styles>
