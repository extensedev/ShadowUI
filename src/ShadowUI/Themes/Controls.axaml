    </ResourceDictionary>
  </Styles.Resources>

  <!-- ButtonGroup: скругления крайних кнопок — глобальные стили по классам -->
  <Style Selector="Button.button-group-first:not(.button-group-last)">
    <Setter Property="CornerRadius" Value="8,0,0,8" />
  </Style>
  <Style Selector="Button.button-group-middle">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
  </Style>
  <Style Selector="Button.button-group-last:not(.button-group-first)">
    <Setter Property="CornerRadius" Value="0,8,8,0" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
  </Style>
  <Style Selector="Button.button-group-first.button-group-last">
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
  </Style>

  <StyleInclude Source="avares://ShadowUI/Themes/Controls/ScrollViewer.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/TabsLarge.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/TabsLegacy.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/TextBox.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/Tooltip.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/ProgressBar.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls/Table.axaml" />
  <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
</Styles>
