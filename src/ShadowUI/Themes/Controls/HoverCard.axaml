<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">

  <!-- HoverCard: preview card shown when hovering over the trigger -->
  <ControlTheme x:Key="{x:Type shadowui:HoverCard}" TargetType="shadowui:HoverCard">
    <!-- Hidden by default until :open is set -->
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- Panel does not clip the popup outside the control bounds -->
        <Panel>

          <!-- Trigger: transparent container around TriggerContent -->
          <Border Name="PART_Trigger"
                  Background="Transparent">
            <ContentPresenter Content="{TemplateBinding TriggerContent}" />
          </Border>

          <!-- Popup is driven from C# code (IsOpen via _popupPart.IsOpen) -->
          <Popup Name="PART_Popup"
                 WindowManagerAddShadowHint="False"
                 IsLightDismissEnabled="True"
                 PlacementTarget="{TemplateBinding}"
                 Placement="BottomEdgeAlignedLeft"
                 VerticalOffset="8">

            <!-- Card: appears with an opacity transition -->
            <Border Name="PART_Card"
                    Background="{DynamicResource ShadowPopoverBrush}"
                    BorderBrush="{DynamicResource ShadowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ShadowRadiusMd}"
                    Padding="16"
                    MaxWidth="320"
                    BoxShadow="{DynamicResource ShadowShadowMd}"
                    Opacity="0">
              <Border.Transitions>
                <Transitions>
                  <!-- Smooth card fade in/out -->
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>

              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
            </Border>
          </Popup>

        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- :open state: show the control -->
    <Style Selector="^:open">
      <Setter Property="IsVisible" Value="True" />
    </Style>

    <!-- :open state: the card becomes visible (Opacity=1) -->
    <Style Selector="^:open /template/ Border#PART_Card">
      <Setter Property="Opacity" Value="1" />
    </Style>

  </ControlTheme>

</ResourceDictionary>
