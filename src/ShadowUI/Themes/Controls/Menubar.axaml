<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- Menubar: horizontal menu bar in the shadcn new-york style -->
  <ControlTheme x:Key="{x:Type shadui:Menubar}" TargetType="shadui:Menubar">
    <Setter Property="Background" Value="{DynamicResource ShadowBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <!-- Bottom border only: the signature shadcn menubar look -->
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="4,0" />
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" />
      </ItemsPanelTemplate>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                Padding="{TemplateBinding Padding}">
          <ItemsPresenter Name="PART_ItemsPresenter"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <!-- MenubarItem: top-level item (File/Edit/View/...) -->
  <ControlTheme x:Key="{x:Type shadui:MenubarItem}" TargetType="shadui:MenubarItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="Padding" Value="12,7,12,8" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusSm}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_LayoutRoot"
                Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
          <Grid ColumnDefinitions="*,Auto">
            <!-- Menu item header -->
            <ContentPresenter Name="PART_HeaderPresenter"
                              Grid.Column="0"
                              Content="{TemplateBinding Header}"
                              VerticalAlignment="Center" />
            <!-- Chevron is hidden at the top level of the Menubar -->
            <Path Name="PART_ChevronPath"
                  Grid.Column="1"
                  IsVisible="False" />
            <!-- Dropdown submenu -->
            <Popup Name="PART_Popup"
                   Grid.Column="0"
                   WindowManagerAddShadowHint="False"
                   IsLightDismissEnabled="False"
                   Placement="BottomEdgeAlignedLeft">
              <Border Background="{DynamicResource ShadowPopoverBrush}"
                      BorderBrush="{DynamicResource ShadowBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource ShadowRadiusMd}"
                      Padding="4"
                      MinWidth="160"
                      Margin="0,4,0,0"
                      BoxShadow="{DynamicResource ShadowShadowMd}">
                <ItemsPresenter Name="PART_ItemsPresenter"
                                ItemsPanel="{TemplateBinding ItemsPanel}" />
              </Border>
            </Popup>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Hover: background highlight -->
    <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <!-- Selected (keyboard nav) -->
    <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <!-- Submenu open -->
    <Style Selector="^[IsSubMenuOpen=True] /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <!-- Disabled item -->
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <!-- No children: chevron always hidden -->
    <Style Selector="^:empty /template/ Path#PART_ChevronPath">
      <Setter Property="IsVisible" Value="False" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
