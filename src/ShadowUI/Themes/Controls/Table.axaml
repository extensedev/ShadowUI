<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Base table styles (analogous to shadcn Table). Composed of Border.table +
       a Grid with rows; cells are TextBlocks with .th / .td classes. -->

  <!-- Table wrapper -->
  <Style Selector="Border.table">
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusLg}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <!-- Header row (muted background) -->
  <Style Selector="Border.thead">
    <Setter Property="Background" Value="{DynamicResource ShadowMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <!-- Regular row (bottom border) -->
  <Style Selector="Border.tr">
    <!-- Transparent (not null): otherwise the row is not hit-tested between cells and hover flickers -->
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>
  <!-- Last row without a bottom border -->
  <Style Selector="Border.tr.last">
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Border.tr:pointerover">
    <Setter Property="Background" Value="{DynamicResource ShadowMutedBrush}" />
  </Style>

  <!-- Header cell -->
  <Style Selector="TextBlock.th">
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Data cell -->
  <Style Selector="TextBlock.td">
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

</Styles>
