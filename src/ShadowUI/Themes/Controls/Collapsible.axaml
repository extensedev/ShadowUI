<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">

  <!-- Container: rounded surface that reveals content when IsExpanded; muted background while open. -->
  <ControlTheme x:Key="{x:Type shadowui:Collapsible}" TargetType="shadowui:Collapsible">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Root"
                Background="Transparent"
                CornerRadius="{DynamicResource ShadowRadiusMd}">
          <StackPanel>
            <!-- Trigger slot: the CollapsibleTrigger goes here -->
            <ContentPresenter Name="PART_Trigger"
                              Content="{TemplateBinding Trigger}"
                              HorizontalAlignment="Stretch" />
            <!-- Content: shown only when IsExpanded=true -->
            <ContentPresenter Name="PART_Content"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              IsVisible="{TemplateBinding IsExpanded}"
                              Padding="12,0,12,10" />
          </StackPanel>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:expanded /template/ Border#PART_Root">
      <Setter Property="Background" Value="{DynamicResource ShadowMutedBrush}" />
    </Style>
  </ControlTheme>

  <!-- Trigger: transparent pass-through (asChild). The child (e.g. a ghost Button) is the only surface. -->
  <ControlTheme x:Key="{x:Type shadowui:CollapsibleTrigger}" TargetType="shadowui:CollapsibleTrigger">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Name="PART_ContentPresenter"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          Cursor="Hand"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
