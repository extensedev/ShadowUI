<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">

  <!-- Container: rounded surface that reveals content when IsExpanded; muted background while open. -->
  <ControlTheme x:Key="{x:Type shadowui:Collapsible}" TargetType="shadowui:Collapsible">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Root"
                Background="Transparent"
                CornerRadius="{DynamicResource ShadowRadiusMd}">
          <!-- Single "*" column: width flows top-down (control/parent -> children), so the body
               never widens the header. A vertical StackPanel would size to its widest child instead. -->
          <Grid RowDefinitions="Auto,Auto">
            <!-- Trigger slot: the CollapsibleTrigger goes here -->
            <ContentPresenter Name="PART_Trigger"
                              Grid.Row="0"
                              Content="{TemplateBinding Trigger}"
                              HorizontalAlignment="Stretch" />
            <!-- Content: shown only when IsExpanded=true. Left/right padding is fixed at 16 to line up
                 with the trigger's text (default ghost Button has 16px padding), so every Collapsible's
                 body sits under the same edge as its header — the indent is always present and uniform. -->
            <ContentPresenter Name="PART_Content"
                              Grid.Row="1"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              IsVisible="{TemplateBinding IsExpanded}"
                              Padding="16,2,16,12" />
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:expanded /template/ Border#PART_Root">
      <Setter Property="Background" Value="{DynamicResource ShadowMutedBrush}" />
    </Style>
  </ControlTheme>

  <!-- Trigger (asChild): header surface with a default accent background, shown in both collapsed and
       expanded states. The child (e.g. a ghost Button) sits on top and fills it. -->
  <ControlTheme x:Key="{x:Type shadowui:CollapsibleTrigger}" TargetType="shadowui:CollapsibleTrigger">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Cursor="Hand"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
