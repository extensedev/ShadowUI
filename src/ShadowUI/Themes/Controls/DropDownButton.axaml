<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- DropDownButton: shadcn dropdown-menu trigger — outline button + chevron.
       Infrastructure previously provided by FluentTheme (own style key). -->
  <ControlTheme x:Key="{x:Type DropDownButton}" TargetType="DropDownButton">
    <Setter Property="Background" Value="{DynamicResource ShadowBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="16,7,12,8" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Border Name="PART_Border"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  BoxShadow="{DynamicResource ShadowShadowXs}">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
              </Transitions>
            </Border.Transitions>
            <Grid ColumnDefinitions="*,Auto">
              <ContentPresenter Name="PART_ContentPresenter"
                                Grid.Column="0"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
              <Path Name="PART_ChevronPath"
                    Grid.Column="1"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Data="M0,0 L4,4 L8,0"
                    Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                    StrokeThickness="1.5"
                    StrokeLineCap="Round" StrokeJoin="Round"
                    IsHitTestVisible="False" />
            </Grid>
          </Border>
          <Border Name="PART_FocusRing"
                  Margin="{DynamicResource ShadowFocusRingMargin}"
                  BorderThickness="{DynamicResource ShadowFocusRingThickness}"
                  CornerRadius="{DynamicResource ShadowRadiusFocusMd}"
                  BorderBrush="{DynamicResource ShadowFocusRingBrush}"
                  IsVisible="False"
                  IsHitTestVisible="False" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <Style Selector="^:pressed /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <Style Selector="^:flyout-open /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <Style Selector="^:focus-visible /template/ Border#PART_FocusRing">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- sizes (match Button) -->
    <Style Selector="^.sm">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="12,5,8,6" />
    </Style>
    <Style Selector="^.lg">
      <Setter Property="Height" Value="40" />
      <Setter Property="Padding" Value="24,7,16,8" />
    </Style>

    <!-- ghost: no border/shadow, accent on hover only -->
    <Style Selector="^.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="^.ghost /template/ Border#PART_Border">
      <Setter Property="BoxShadow" Value="none" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
