<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ControlTheme x:Key="{x:Type ToggleButton}" TargetType="ToggleButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowInputBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Panel>
            <!-- hover layer (muted): opacity is animated, no brush flicker -->
            <Border Name="PART_Hover" Opacity="0"
                    Background="{DynamicResource ShadowMutedBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>
            </Border>
            <!-- active/pressed state layer (accent) on top of hover -->
            <Border Name="PART_Active" Opacity="0"
                    Background="{DynamicResource ShadowAccentBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>
            </Border>
            <ContentPresenter Content="{TemplateBinding Content}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Panel>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ Border#PART_Hover">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:pressed /template/ Border#PART_Active">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:checked /template/ Border#PART_Active">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:checked">
      <Setter Property="Foreground" Value="{DynamicResource ShadowAccentForegroundBrush}" />
    </Style>

    <Style Selector="^.outline">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowInputBrush}" />
    </Style>
    <Style Selector="^.outline /template/ Border#PART_Border">
      <Setter Property="BoxShadow" Value="{DynamicResource ShadowShadowXs}" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
