<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="using:Avalonia.Controls.Primitives"
                    xmlns:shadowui="using:ShadowUI">

  <ControlTheme x:Key="{x:Type shadowui:Dialog}" TargetType="shadowui:Dialog">
    <Setter Property="ZIndex" Value="1000" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- Zero-footprint placeholder: PART_Scrim is reparented into the window's
             OverlayLayer at runtime so the overlay always covers the whole window,
             regardless of where <shadowui:Dialog> sits in the visual tree. -->
        <Panel Name="PART_Root" IsVisible="False">
        <!-- Scrim (overlay), fills the window; click outside the card closes.
             Sized to the OverlayLayer it is reparented into (the layer is Canvas-like
             and does not stretch its children, so an explicit size is required). -->
        <Border Name="PART_Scrim"
                Background="#99000000"
                Width="{Binding $parent[primitives:OverlayLayer].Bounds.Width}"
                Height="{Binding $parent[primitives:OverlayLayer].Bounds.Height}"
                Focusable="True"
                IsHitTestVisible="False"
                Opacity="0">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
          </Border.Transitions>

          <!-- Card -->
          <Border Name="PART_Card"
                  Background="{DynamicResource ShadowBackgroundBrush}"
                  BorderBrush="{DynamicResource ShadowBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource ShadowRadiusLg}"
                  BoxShadow="{DynamicResource ShadowShadowMd}"
                  Padding="24"
                  Width="{TemplateBinding CardWidth}"
                  MinWidth="{TemplateBinding CardMinWidth}"
                  MaxWidth="{TemplateBinding CardMaxWidth}"
                  Height="{TemplateBinding CardHeight}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="24">
            <Border.MaxHeight>
              <MultiBinding Converter="{x:Static shadowui:DialogCardMaxHeightConverter.Instance}" ConverterParameter="48">
                <TemplateBinding Property="CardMaxHeight" />
                <Binding Path="$parent[primitives:OverlayLayer].Bounds.Height" />
              </MultiBinding>
            </Border.MaxHeight>
            <Grid RowDefinitions="Auto,Auto,*,Auto">

              <!-- Title -->
              <ContentPresenter Grid.Row="0"
                                Name="PART_Title"
                                Content="{TemplateBinding Title}"
                                IsVisible="{TemplateBinding Title, Converter={x:Static ObjectConverters.IsNotNull}}"
                                TextElement.FontSize="18"
                                TextElement.FontWeight="SemiBold"
                                TextElement.Foreground="{DynamicResource ShadowForegroundBrush}"
                                Margin="0,0,0,20" />

              <!-- Description -->
              <ContentPresenter Grid.Row="1"
                                Name="PART_Description"
                                Content="{TemplateBinding Description}"
                                IsVisible="{TemplateBinding Description, Converter={x:Static ObjectConverters.IsNotNull}}"
                                TextElement.FontSize="14"
                                TextElement.Foreground="{DynamicResource ShadowMutedForegroundBrush}"
                                TextBlock.TextWrapping="Wrap"
                                Margin="0,0,24,28" />

              <!-- Body -->
              <ScrollViewer Grid.Row="2"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
              </ScrollViewer>

              <!-- Footer (actions) -->
              <ContentPresenter Grid.Row="3"
                                Name="PART_Footer"
                                Content="{TemplateBinding Footer}"
                                IsVisible="{TemplateBinding Footer, Converter={x:Static ObjectConverters.IsNotNull}}"
                                HorizontalContentAlignment="Right"
                                Margin="0,20,0,0" />

              <!-- Close button -->
              <Button Name="PART_CloseButton"
                      Grid.Row="0"
                      Classes="ghost icon"
                      Width="28" Height="28"
                      Padding="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-4,-4,0"
                      IsVisible="{TemplateBinding ShowCloseButton}"
                      ToolTip.Tip="Close">
                <Viewbox Width="16" Height="16">
                  <Path Data="M 6 6 L 18 18 M 18 6 L 6 18"
                        Width="24" Height="24" Stretch="None"
                        Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                        StrokeThickness="2" StrokeLineCap="Round" />
                </Viewbox>
              </Button>

            </Grid>
          </Border>
        </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
