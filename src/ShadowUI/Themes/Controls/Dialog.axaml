<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">

  <ControlTheme x:Key="{x:Type shadowui:Dialog}" TargetType="shadowui:Dialog">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="ZIndex" Value="1000" />
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- Scrim (overlay), fills the host; click outside the card closes -->
        <Border Name="PART_Scrim"
                Background="#99000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Opacity="0">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
          </Border.Transitions>

          <!-- Card -->
          <Border Name="PART_Card"
                  Background="{DynamicResource ShadowBackgroundBrush}"
                  BorderBrush="{DynamicResource ShadowBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource ShadowRadiusLg}"
                  BoxShadow="{DynamicResource ShadowShadowMd}"
                  Padding="24"
                  MinWidth="320" MaxWidth="480"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="24">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">

              <!-- Title -->
              <ContentPresenter Grid.Row="0"
                                Name="PART_Title"
                                Content="{TemplateBinding Title}"
                                IsVisible="{TemplateBinding Title, Converter={x:Static ObjectConverters.IsNotNull}}"
                                TextElement.FontSize="18"
                                TextElement.FontWeight="SemiBold"
                                TextElement.Foreground="{DynamicResource ShadowForegroundBrush}"
                                Margin="0,0,0,6" />

              <!-- Description -->
              <ContentPresenter Grid.Row="1"
                                Name="PART_Description"
                                Content="{TemplateBinding Description}"
                                IsVisible="{TemplateBinding Description, Converter={x:Static ObjectConverters.IsNotNull}}"
                                TextElement.FontSize="14"
                                TextElement.Foreground="{DynamicResource ShadowMutedForegroundBrush}"
                                TextBlock.TextWrapping="Wrap"
                                Margin="0,0,24,28" />

              <!-- Body -->
              <ContentPresenter Grid.Row="2"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />

              <!-- Footer (actions) -->
              <ContentPresenter Grid.Row="3"
                                Name="PART_Footer"
                                Content="{TemplateBinding Footer}"
                                IsVisible="{TemplateBinding Footer, Converter={x:Static ObjectConverters.IsNotNull}}"
                                HorizontalContentAlignment="Right"
                                Margin="0,20,0,0" />

              <!-- Close button -->
              <Button Name="PART_CloseButton"
                      Grid.Row="0"
                      Classes="ghost icon"
                      Width="28" Height="28"
                      Padding="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-4,-4,0"
                      IsVisible="{TemplateBinding ShowCloseButton}"
                      ToolTip.Tip="Close">
                <Viewbox Width="16" Height="16">
                  <Path Data="M 6 6 L 18 18 M 18 6 L 6 18"
                        Width="24" Height="24" Stretch="None"
                        Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                        StrokeThickness="2" StrokeLineCap="Round" />
                </Viewbox>
              </Button>

            </Grid>
          </Border>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Open: show + fade in -->
    <Style Selector="^:open">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:open /template/ Border#PART_Scrim">
      <Setter Property="Opacity" Value="1" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
