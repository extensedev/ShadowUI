<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">
  <ControlTheme x:Key="{x:Type shadui:Card}" TargetType="shadui:Card">
    <Setter Property="Background" Value="{DynamicResource ShadowCardBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowCardForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusXl}" />
    <Setter Property="Padding" Value="24" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                BoxShadow="{DynamicResource ShadowShadowSm}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type shadui:CardTitle}" TargetType="shadui:CardTitle">
    <Setter Property="Foreground" Value="{DynamicResource ShadowCardForegroundBrush}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Content="{TemplateBinding Content}" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type shadui:CardDescription}" TargetType="shadui:CardDescription">
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Content="{TemplateBinding Content}" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
