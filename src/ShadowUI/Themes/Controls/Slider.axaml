<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ControlTheme x:Key="ShadowSliderThumb" TargetType="Thumb">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Background" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                BoxShadow="{DynamicResource ShadowShadowSm}"
                CornerRadius="9999" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="ShadowSliderRepeat" TargetType="RepeatButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" CornerRadius="9999" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type Slider}" TargetType="Slider">
    <Setter Property="Background" Value="{DynamicResource ShadowSecondaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="Transparent">
          <Grid>
            <Border Height="6" CornerRadius="9999"
                    Background="{TemplateBinding Background}"
                    VerticalAlignment="Center" />
            <Track Name="PART_Track"
                   Minimum="{TemplateBinding Minimum}"
                   Maximum="{TemplateBinding Maximum}"
                   Value="{TemplateBinding Value, Mode=TwoWay}"
                   Orientation="Horizontal">
              <Track.DecreaseButton>
                <RepeatButton Name="PART_DecreaseButton"
                              Theme="{StaticResource ShadowSliderRepeat}"
                              Height="6" VerticalAlignment="Center"
                              Background="{DynamicResource ShadowPrimaryBrush}" />
              </Track.DecreaseButton>
              <Track.IncreaseButton>
                <RepeatButton Name="PART_IncreaseButton"
                              Theme="{StaticResource ShadowSliderRepeat}"
                              Height="6" VerticalAlignment="Center"
                              Background="Transparent" />
              </Track.IncreaseButton>
              <Thumb Theme="{StaticResource ShadowSliderThumb}" />
            </Track>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
