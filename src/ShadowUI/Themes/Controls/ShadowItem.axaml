<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- ShadowItem theme: generic list item with an icon, texts and a trailing action -->
  <ControlTheme x:Key="{x:Type shadui:ShadowItem}" TargetType="shadui:ShadowItem">
    <Setter Property="Padding" Value="8,5,8,6" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{DynamicResource ShadowCardBrush}"
                CornerRadius="{DynamicResource ShadowRadiusMd}"
                Padding="{TemplateBinding Padding}">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
          </Border.Transitions>

          <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- icon: hidden when null -->
            <ContentPresenter Name="PART_Icon"
                              Grid.Column="0"
                              Content="{TemplateBinding Icon}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />

            <!-- primary and secondary text -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="2">
              <TextBlock Name="PART_PrimaryText"
                         Text="{TemplateBinding PrimaryText}"
                         Foreground="{DynamicResource ShadowForegroundBrush}"
                         FontSize="14" />
              <TextBlock Name="PART_SecondaryText"
                         Text="{TemplateBinding SecondaryText}"
                         Foreground="{DynamicResource ShadowMutedForegroundBrush}"
                         FontSize="12"
                         IsVisible="{TemplateBinding SecondaryText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <!-- trailing action: hidden when null -->
            <ContentPresenter Name="PART_TrailingAction"
                              Grid.Column="2"
                              Content="{TemplateBinding TrailingAction}"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"
                              IsVisible="{TemplateBinding TrailingAction, Converter={x:Static ObjectConverters.IsNotNull}}" />

          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- hover state -->
    <Style Selector="^:pointerover /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>

  </ControlTheme>

</ResourceDictionary>
