<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">

  <!-- DatePicker: date input field with an icon button and a popup ShadowCalendar -->
  <ControlTheme x:Key="{x:Type shadowui:DatePicker}" TargetType="shadowui:DatePicker">
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- Panel: root element, does not clip the popup -->
        <Panel>

          <!-- Outer border wrapping the TextBox and the open button -->
          <Border Name="PART_Border"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{DynamicResource ShadowInputBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource ShadowRadiusMd}"
                  ClipToBounds="True">

            <!-- Grid: col 0 = TextBox, col 1 = icon button -->
            <Grid ColumnDefinitions="*,Auto" ClipToBounds="False">

              <!-- Date input field -->
              <TextBox Name="PART_TextBox"
                       Grid.Column="0"
                       Classes="transparent"
                       PlaceholderText="{TemplateBinding Watermark}"
                       BorderThickness="0"
                       Background="Transparent"
                       VerticalAlignment="Stretch"
                       VerticalContentAlignment="Center"
                       Padding="12,0,8,0" />

              <!-- Button that opens the Popup, with a calendar icon (shadcn: ghost size-6 right-2) -->
              <Button Name="PART_PopupButton"
                      Grid.Column="1"
                      Classes="ghost icon"
                      Width="24" Height="24"
                      VerticalAlignment="Center"
                      Margin="0,0,6,0"
                      CornerRadius="{DynamicResource ShadowRadiusSm}"
                      Padding="0">
                <!-- Lucide calendar in final pixel coordinates (24px viewbox scaled to 14px) -->
                <Path Data="M 4.5 1 V 3.5 M 9.5 1 V 3.5 M 1.5 6 H 12.5 M 3 2.5 H 11 A 1.5 1.5 0 0 1 12.5 4 V 11 A 1.5 1.5 0 0 1 11 12.5 H 3 A 1.5 1.5 0 0 1 1.5 11 V 4 A 1.5 1.5 0 0 1 3 2.5 Z"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                      StrokeThickness="1.25"
                      StrokeLineCap="Round" StrokeJoin="Round"
                      Fill="Transparent" />
              </Button>

            </Grid>
          </Border>

          <Border Name="PART_FocusRing"
                  Margin="{DynamicResource ShadowFocusRingMargin}"
                  BorderThickness="{DynamicResource ShadowFocusRingThickness}"
                  CornerRadius="{DynamicResource ShadowRadiusFocusMd}"
                  BorderBrush="{DynamicResource ShadowFocusRingBrush}"
                  IsVisible="False"
                  IsHitTestVisible="False" />

          <!-- Popup with the embedded ShadowCalendar -->
          <Popup Name="PART_Popup"
                 PlacementTarget="{TemplateBinding}"
                 Placement="BottomEdgeAlignedLeft"
                 VerticalOffset="4"
                 IsLightDismissEnabled="True"
                 WindowManagerAddShadowHint="False">
            <!-- The popup border is the only frame: the calendar inside is stripped
                 of its own border/background (shadcn popover p-0 + borderless calendar) -->
            <Border Background="{DynamicResource ShadowPopoverBrush}"
                    BorderBrush="{DynamicResource ShadowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ShadowRadiusMd}"
                    BoxShadow="{DynamicResource ShadowShadowMd}">
              <shadowui:ShadowCalendar Name="PART_Calendar"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="12" />
            </Border>
          </Popup>

        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- Focus inside the control: add a focus ring around the border -->
    <Style Selector="^:focus-within /template/ Border#PART_Border">
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowRingBrush}" />
    </Style>
    <Style Selector="^:focus-within /template/ Border#PART_FocusRing">
      <Setter Property="IsVisible" Value="True" />
    </Style>

  </ControlTheme>

</ResourceDictionary>
