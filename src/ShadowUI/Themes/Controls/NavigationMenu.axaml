<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- Horizontal NavigationMenu container -->
  <ControlTheme x:Key="{x:Type shadui:NavigationMenu}" TargetType="shadui:NavigationMenu">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}">
          <ItemsPresenter Name="PART_ItemsPresenter"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
        </Border>
      </ControlTemplate>
    </Setter>
    <!-- Horizontal layout via ItemsPanel -->
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" Spacing="4" />
      </ItemsPanelTemplate>
    </Setter>
  </ControlTheme>

  <!-- Navigation menu item with a hover flyout -->
  <ControlTheme x:Key="{x:Type shadui:NavigationMenuItem}" TargetType="shadui:NavigationMenuItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <!-- Trigger (header button): opens the flyout on pointer hover -->
          <Border Name="PART_Trigger"
                  Background="Transparent"
                  CornerRadius="{DynamicResource ShadowRadiusMd}"
                  Padding="12,8"
                  Cursor="Hand">
              <!-- Menu item header (trigger text) -->
            <ContentPresenter Content="{TemplateBinding Header}"
                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              TextElement.FontSize="{TemplateBinding FontSize}"
                              TextElement.Foreground="{TemplateBinding Foreground}" />
          </Border>

          <!-- Flyout submenu (opens on hover) -->
          <Popup Name="PART_Popup"
                 IsLightDismissEnabled="True"
                 Placement="BottomEdgeAlignedLeft"
                 VerticalOffset="8"
                 WindowManagerAddShadowHint="False"
                 IsOpen="{TemplateBinding IsFlyoutOpen, Mode=OneWay}">
            <Border Background="{DynamicResource ShadowPopoverBrush}"
                    BorderBrush="{DynamicResource ShadowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ShadowRadiusMd}"
                    Padding="16"
                    BoxShadow="{DynamicResource ShadowShadowMd}"
                    MinWidth="200">
              <!-- Submenu content -->
              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
            </Border>
          </Popup>
        </Panel>
      </ControlTemplate>
    </Setter>

    <!-- Hover state: trigger highlight -->
    <Style Selector="^:pointerover /template/ Border#PART_Trigger">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>

    <!-- Open-flyout state: trigger highlight -->
    <Style Selector="^:flyout-open /template/ Border#PART_Trigger">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
