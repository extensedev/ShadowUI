<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">
  <ControlTheme x:Key="{x:Type shadowui:Kbd}" TargetType="shadowui:Kbd">
    <Setter Property="Background" Value="{DynamicResource ShadowMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusSm}" />
    <Setter Property="Padding" Value="6,2" />
    <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
