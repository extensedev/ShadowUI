<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shadowui="using:ShadowUI">

  <!-- ── legacytabs: segmented with a FILLED active tab (previous look) ── -->
  <Style Selector="TabControl.legacytabs TabItem:selected /template/ Border#PART_Border">
    <Setter Property="Background" Value="{DynamicResource ShadowBackgroundBrush}" />
    <Setter Property="BoxShadow" Value="{DynamicResource ShadowShadowSm}" />
  </Style>

  <!-- ── Underline variant via flag: shadowui:Tabs.Underline="True" ── -->
  <Style Selector="TabControl[(shadowui|Tabs.Underline)=True]">
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" Spacing="4" />
      </ItemsPanelTemplate>
    </Setter>
  </Style>

  <!-- container: transparent + bottom baseline -->
  <Style Selector="TabControl[(shadowui|Tabs.Underline)=True] /template/ Border#PART_ListBorder">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TabControl[(shadowui|Tabs.Underline)=True] TabItem">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="2,8" />
    <Setter Property="Margin" Value="6,0" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <!-- permanent (transparent) bottom border: the underline does not change the size -->
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>
  <Style Selector="TabControl[(shadowui|Tabs.Underline)=True] TabItem:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
  </Style>
  <Style Selector="TabControl[(shadowui|Tabs.Underline)=True] TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
  </Style>

  <!-- selected: underline, no segment background/shadow/border -->
  <Style Selector="TabControl[(shadowui|Tabs.Underline)=True] TabItem:selected /template/ Border#PART_Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowForegroundBrush}" />
  </Style>

</Styles>
