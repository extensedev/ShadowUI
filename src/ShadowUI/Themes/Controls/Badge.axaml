<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">
  <ControlTheme x:Key="{x:Type shadowui:Badge}" TargetType="shadowui:Badge">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9999" />
    <!-- top 1px < bottom: line-box centering leaves the glyph 1px low; trim top to center. -->
    <Setter Property="Padding" Value="8,1,8,2" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^.secondary">
      <Setter Property="Background" Value="{DynamicResource ShadowSecondaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowSecondaryForegroundBrush}" />
    </Style>
    <Style Selector="^.destructive">
      <Setter Property="Background" Value="{DynamicResource ShadowDestructiveBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowDestructiveForegroundBrush}" />
    </Style>
    <Style Selector="^.outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    </Style>
    <!-- Status badges use the soft treatment (tinted surface + bright colored text):
         reads cleanly in both themes, unlike a saturated fill under near-black text. -->
    <Style Selector="^.success">
      <Setter Property="Background" Value="{DynamicResource ShadowSuccessSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowSuccessSoftForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowSuccessSoftBorderBrush}" />
    </Style>
    <Style Selector="^.warning">
      <Setter Property="Background" Value="{DynamicResource ShadowWarningSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowWarningSoftForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowWarningSoftBorderBrush}" />
    </Style>
    <Style Selector="^.info">
      <Setter Property="Background" Value="{DynamicResource ShadowInfoSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowInfoSoftForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowInfoSoftBorderBrush}" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
