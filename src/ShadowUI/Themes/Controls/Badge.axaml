<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">
  <ControlTheme x:Key="{x:Type shadui:Badge}" TargetType="shadui:Badge">
    <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="9999" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^.secondary">
      <Setter Property="Background" Value="{DynamicResource ShadowSecondaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowSecondaryForegroundBrush}" />
    </Style>
    <Style Selector="^.destructive">
      <Setter Property="Background" Value="{DynamicResource ShadowDestructiveBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowDestructiveForegroundBrush}" />
    </Style>
    <Style Selector="^.outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    </Style>
    <Style Selector="^.success">
      <Setter Property="Background" Value="{DynamicResource ShadowSuccessBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowSuccessForegroundBrush}" />
    </Style>
    <Style Selector="^.warning">
      <Setter Property="Background" Value="{DynamicResource ShadowWarningBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowWarningForegroundBrush}" />
    </Style>
    <Style Selector="^.info">
      <Setter Property="Background" Value="{DynamicResource ShadowInfoBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowInfoForegroundBrush}" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
