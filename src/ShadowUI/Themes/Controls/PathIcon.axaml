<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Infrastructure theme previously provided by FluentTheme.
       Without a template a PathIcon renders nothing in a standalone theme.
       No Foreground setter: the icon inherits Foreground from its parent,
       so button variants (destructive, ghost, ...) tint their icons. -->
  <ControlTheme x:Key="{x:Type PathIcon}" TargetType="PathIcon">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}">
          <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
            <Path Data="{TemplateBinding Data}"
                  Fill="{TemplateBinding Foreground}"
                  Stretch="Uniform" />
          </Viewbox>
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
