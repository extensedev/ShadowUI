<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadowui="using:ShadowUI">

  <!-- Sheet theme: sliding overlay panel (Right / Bottom) -->
  <ControlTheme x:Key="{x:Type shadowui:Sheet}" TargetType="shadowui:Sheet">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="ZIndex" Value="1000" />
    <!-- Stays realized (not IsVisible=False) so the panel is rendered off-screen at its closed
         position from the start; the very first open then slides in like every subsequent open.
         When closed it is click-through via IsHitTestVisible=False. -->
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="PanelCornerRadius" Value="{DynamicResource ShadowRadiusLg}" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- Scrim: dimming; clicking outside closes the panel -->
        <Border Name="PART_Scrim"
                Background="#99000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Opacity="0">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
          </Border.Transitions>

          <!-- Panel: slides in from the configured side via RenderTransform (set from code) -->
          <Border Name="PART_Panel"
                  Background="{DynamicResource ShadowBackgroundBrush}"
                  BorderBrush="{DynamicResource ShadowBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{TemplateBinding PanelCornerRadius}"
                  Margin="{TemplateBinding PanelMargin}"
                  BoxShadow="{DynamicResource ShadowShadowMd}">
            <Border.Transitions>
              <Transitions>
                <!-- Panel slide in/out animation -->
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" />
              </Transitions>
            </Border.Transitions>

            <Panel>
            <!-- Panel content: title, description, content, close button -->
            <Grid Margin="24" RowDefinitions="Auto,Auto,*">

              <!-- Title -->
              <ContentPresenter Grid.Row="0"
                                Name="PART_Title"
                                Content="{TemplateBinding Title}"
                                IsVisible="{TemplateBinding Title, Converter={x:Static ObjectConverters.IsNotNull}}"
                                TextElement.FontSize="18"
                                TextElement.FontWeight="SemiBold"
                                TextElement.Foreground="{DynamicResource ShadowForegroundBrush}"
                                Margin="0,0,0,6" />

              <!-- Description -->
              <ContentPresenter Grid.Row="1"
                                Name="PART_Description"
                                Content="{TemplateBinding Description}"
                                IsVisible="{TemplateBinding Description, Converter={x:Static ObjectConverters.IsNotNull}}"
                                TextElement.FontSize="14"
                                TextElement.Foreground="{DynamicResource ShadowMutedForegroundBrush}"
                                TextBlock.TextWrapping="Wrap"
                                Margin="0,0,24,16" />

              <!-- Main content -->
              <ScrollViewer Grid.Row="2"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                <ContentPresenter Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
              </ScrollViewer>

              <!-- Close button -->
              <Button Name="PART_CloseButton"
                      Grid.Row="0"
                      Classes="ghost icon"
                      Width="28" Height="28"
                      Padding="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-4,-4,0"
                      IsVisible="{TemplateBinding ShowCloseButton}"
                      ToolTip.Tip="Close">
                <Viewbox Width="16" Height="16">
                  <Path Data="M 6 6 L 18 18 M 18 6 L 6 18"
                        Width="24" Height="24" Stretch="None"
                        Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                        StrokeThickness="2" StrokeLineCap="Round" />
                </Viewbox>
              </Button>

            </Grid>

            <!-- Resize grip on the inner edge (left for Right, top for Bottom); positioned per side below -->
            <Border Name="PART_ResizeGrip"
                    Background="Transparent"
                    IsVisible="{TemplateBinding IsResizable}" />
            </Panel>
          </Border>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Open state: allow interaction (scrim catches outside clicks, panel is interactive) -->
    <Style Selector="^:open">
      <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <!-- Scrim: fades in when opening -->
    <Style Selector="^:open /template/ Border#PART_Scrim">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Overlay disabled: keep the panel modal but drop the dimming -->
    <Style Selector="^:no-overlay /template/ Border#PART_Scrim">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Sides: panel docking (size + slide transform are driven from code) -->
    <Style Selector="^:side-right /template/ Border#PART_Panel">
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="^:side-bottom /template/ Border#PART_Panel">
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- Resize grip: docked to the inner edge, cursor hints the drag axis -->
    <Style Selector="^:side-right /template/ Border#PART_ResizeGrip">
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="Width" Value="6" />
      <Setter Property="Cursor" Value="SizeWestEast" />
    </Style>

    <Style Selector="^:side-bottom /template/ Border#PART_ResizeGrip">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="Height" Value="6" />
      <Setter Property="Cursor" Value="SizeNorthSouth" />
    </Style>

    <Style Selector="^ /template/ Border#PART_ResizeGrip:pointerover">
      <Setter Property="Background" Value="{DynamicResource ShadowBorderBrush}" />
    </Style>

  </ControlTheme>

</ResourceDictionary>
