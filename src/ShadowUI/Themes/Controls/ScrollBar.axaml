<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Тонкий скроллбар в стиле shadcn ScrollArea -->
  <ControlTheme x:Key="ShadowScrollThumb" TargetType="Thumb">
    <Setter Property="Background" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}" CornerRadius="9999" Margin="2" />
      </ControlTemplate>
    </Setter>
    <Style Selector="^:pointerover /template/ Border">
      <Setter Property="Background" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="MinWidth" Value="8" />
    <Setter Property="MinHeight" Value="8" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}">
          <Track Name="PART_Track"
                 Minimum="{TemplateBinding Minimum}"
                 Maximum="{TemplateBinding Maximum}"
                 Value="{TemplateBinding Value, Mode=TwoWay}"
                 ViewportSize="{TemplateBinding ViewportSize}"
                 Orientation="{TemplateBinding Orientation}">
            <Thumb Theme="{StaticResource ShadowScrollThumb}" />
          </Track>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:vertical">
      <Setter Property="Width" Value="8" />
    </Style>
    <Style Selector="^:vertical /template/ Track#PART_Track">
      <Setter Property="IsDirectionReversed" Value="True" />
    </Style>
    <Style Selector="^:horizontal">
      <Setter Property="Height" Value="8" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
