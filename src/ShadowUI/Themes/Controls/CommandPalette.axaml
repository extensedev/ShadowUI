<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- CommandPalette theme: full-screen overlay with search and a command list -->
  <ControlTheme x:Key="{x:Type shadui:CommandPalette}" TargetType="shadui:CommandPalette">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="ZIndex" Value="1000" />
    <Setter Property="IsVisible" Value="False" />
    <Setter Property="Focusable" Value="True" />
    <Setter Property="Template">
      <ControlTemplate>
        <!-- Scrim: background dimming; clicking it closes the palette -->
        <Border Name="PART_Scrim"
                Background="#CC000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Opacity="0">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
          </Border.Transitions>

          <!-- Centers the search card -->
          <Grid>
            <!-- search card -->
            <Border Name="PART_Card"
                    Width="560"
                    MaxHeight="420"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource ShadowPopoverBrush}"
                    BorderBrush="{DynamicResource ShadowBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ShadowRadiusLg}"
                    BoxShadow="{DynamicResource ShadowShadowMd}">
              <Border.Transitions>
                <Transitions>
                  <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>

              <Grid RowDefinitions="Auto,Auto,*">

                <!-- search -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="12,12,12,0">

                  <!-- search icon -->
                  <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Path Data="M 21 21 L 16.65 16.65 M 19 11 A 8 8 0 1 1 3 11 A 8 8 0 0 1 19 11"
                          Width="24" Height="24"
                          Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Stretch="None"
                          Fill="Transparent" />
                  </Viewbox>

                  <!-- input field -->
                  <TextBox Name="PART_SearchBox"
                           Grid.Column="1"
                           Classes="transparent"
                           BorderThickness="0"
                           Background="Transparent"
                           Padding="8,0,8,0"
                           PlaceholderText="{TemplateBinding SearchPlaceholder}"
                           VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           FontSize="14" />

                  <!-- Esc badge -->
                  <Border Grid.Column="2"
                          Background="{DynamicResource ShadowMutedBrush}"
                          CornerRadius="{DynamicResource ShadowRadiusSm}"
                          Padding="4,2"
                          Margin="4,0,0,0"
                          VerticalAlignment="Center">
                    <TextBlock Text="Esc"
                               FontSize="11"
                               Foreground="{DynamicResource ShadowMutedForegroundBrush}" />
                  </Border>

                </Grid>

                <!-- separator -->
                <Separator Grid.Row="1" Margin="0,10,0,0" />

                <!-- command list -->
                <ScrollViewer Grid.Row="2" Padding="0,6,0,6">
                  <ListBox Name="PART_ItemsListBox"
                           Background="Transparent"
                           BorderThickness="0"
                           Padding="4,0,4,0">
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="shadui:CommandItem">
                        <Border Padding="8,6"
                                CornerRadius="{DynamicResource ShadowRadiusMd}">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Header}"
                                       FontSize="14"
                                       Foreground="{DynamicResource ShadowForegroundBrush}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Description}"
                                       FontSize="12"
                                       Foreground="{DynamicResource ShadowMutedForegroundBrush}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                      <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
                      </Style>
                      <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
                        <Setter Property="TextElement.Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
                      </Style>
                    </ListBox.Styles>
                  </ListBox>
                </ScrollViewer>

              </Grid>
            </Border>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- closed state: card slightly scaled down -->
    <Style Selector="^ /template/ Border#PART_Card">
      <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>

    <!-- open state -->
    <Style Selector="^:open">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:open /template/ Border#PART_Scrim">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:open /template/ Border#PART_Card">
      <Setter Property="RenderTransform" Value="scale(1)" />
    </Style>

  </ControlTheme>

</ResourceDictionary>
