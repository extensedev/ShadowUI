<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- ButtonGroup — группа кнопок с единой границей -->
  <ControlTheme x:Key="{x:Type shadui:ButtonGroup}" TargetType="shadui:ButtonGroup">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <StackPanel Orientation="{Binding Orientation, RelativeSource={RelativeSource AncestorType=shadui:ButtonGroup}}"
                    Spacing="0" />
      </ItemsPanelTemplate>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <ItemsPresenter Name="PART_ItemsPresenter"
                        ItemsPanel="{TemplateBinding ItemsPanel}" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
