<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- Carousel theme: slider with prev/next navigation and a dot indicator -->
  <ControlTheme x:Key="{x:Type shadui:Carousel}" TargetType="shadui:Carousel">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>

        <!-- Root Grid: Row 0 = slides + buttons, Row 1 = navigation dots -->
        <Grid RowDefinitions="*,Auto">

          <!-- Row 0: slides (ListBox) and overlay buttons -->
          <Grid Grid.Row="0">

            <!-- ContentPresenter: shows only the current slide -->
            <ContentPresenter Name="PART_ItemsHost"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch" />

            <!-- Overlay with Prev and Next buttons -->
            <Grid>
              <!-- Previous button -->
              <Button Name="PART_PrevButton"
                      Classes="ghost"
                      Content="&#8592;"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Margin="8,0"
                      ZIndex="10" />

              <!-- Next button -->
              <Button Name="PART_NextButton"
                      Classes="ghost"
                      Content="&#8594;"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Margin="8,0"
                      ZIndex="10" />
            </Grid>

          </Grid>

          <!-- Row 1: dot navigation; dots are created from code -->
          <StackPanel Name="PART_DotsPanel"
                      Grid.Row="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Margin="0,8,0,0" />

        </Grid>

      </ControlTemplate>
    </Setter>

    <!-- Dot indicator styles live in Controls.axaml (global):
         dots are created from code-behind, and ControlTheme child styles cannot reach them. -->

  </ControlTheme>

</ResourceDictionary>
