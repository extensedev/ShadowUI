<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ControlTheme x:Key="{x:Type ToggleSwitch}" TargetType="ToggleSwitch">
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Grid Width="32" Height="18" VerticalAlignment="Center">
            <!-- Base (off) track -->
            <Border Name="PART_Track" CornerRadius="9999"
                    Background="{DynamicResource ShadowInputBrush}" />
            <!-- On-color overlay: smooth fade instead of a brush swap (no flicker) -->
            <Border Name="SwitchBackground" CornerRadius="9999" Opacity="0"
                    Background="{DynamicResource ShadowPrimaryBrush}">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
              </Border.Transitions>
            </Border>
            <!-- Knob -->
            <Canvas Name="PART_SwitchKnob" Width="32" Height="18" HorizontalAlignment="Left">
              <Border Name="SwitchKnob" Canvas.Left="1" Canvas.Top="1"
                      Width="16" Height="16" CornerRadius="9999" ClipToBounds="True"
                      BoxShadow="{DynamicResource ShadowShadowSm}">
                <Border.Transitions>
                  <Transitions>
                    <DoubleTransition Property="Canvas.Left" Duration="0:0:0.15">
                      <DoubleTransition.Easing>
                        <QuarticEaseOut />
                      </DoubleTransition.Easing>
                    </DoubleTransition>
                  </Transitions>
                </Border.Transitions>
                <Panel>
                  <Border Name="KnobOff" CornerRadius="9999" Opacity="1"
                          Background="{DynamicResource ShadowSwitchThumbBrush}">
                    <Border.Transitions>
                      <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.05" />
                      </Transitions>
                    </Border.Transitions>
                  </Border>
                  <Border Name="KnobOn" CornerRadius="9999" Opacity="0"
                          Background="{DynamicResource ShadowSwitchThumbCheckedBrush}">
                    <Border.Transitions>
                      <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.05" />
                      </Transitions>
                    </Border.Transitions>
                  </Border>
                </Panel>
              </Border>
              <Grid Name="PART_MovingKnobs" />
              <!-- empty PART_MovingKnobs enables Avalonia's built-in toggle animation -->
            </Canvas>
            <Border Name="PART_FocusRing"
                    Margin="{DynamicResource ShadowFocusRingMargin}"
                    BorderThickness="{DynamicResource ShadowFocusRingThickness}"
                    CornerRadius="9999"
                    BorderBrush="{DynamicResource ShadowFocusRingBrush}"
                    IsVisible="False"
                    IsHitTestVisible="False" />
          </Grid>
          <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center" />
        </StackPanel>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:unchecked /template/ Border#SwitchKnob">
      <Setter Property="Canvas.Left" Value="1" />
    </Style>
    <Style Selector="^:checked /template/ Border#SwitchBackground">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:checked /template/ Border#SwitchKnob">
      <Setter Property="Canvas.Left" Value="15" />
    </Style>
    <Style Selector="^:checked /template/ Border#KnobOff">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="^:checked /template/ Border#KnobOn">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:focus-visible /template/ Border#PART_FocusRing">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
