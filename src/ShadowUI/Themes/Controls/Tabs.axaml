<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ControlTheme x:Key="{x:Type TabControl}" TargetType="TabControl">
    <Setter Property="Template">
      <ControlTemplate>
        <DockPanel>
          <Border Name="PART_ListBorder"
                  DockPanel.Dock="Top"
                  Background="{DynamicResource ShadowMutedBrush}"
                  CornerRadius="{DynamicResource ShadowRadiusLg}"
                  Padding="3" HorizontalAlignment="Left">
            <ItemsPresenter Name="PART_ItemsPresenter"
                            ItemsPanel="{TemplateBinding ItemsPanel}" />
          </Border>
          <ContentPresenter Name="PART_SelectedContentHost"
                            Content="{TemplateBinding SelectedContent}"
                            ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                            Margin="0,8,0,0" />
        </DockPanel>
      </ControlTemplate>
    </Setter>
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" Spacing="4" />
      </ItemsPanelTemplate>
    </Setter>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type TabItem}" TargetType="TabItem">
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <!-- constant 1px border (transparent when inactive) so selecting doesn't resize → no jitter -->
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
    <!-- active = outline only (no fill, no shadow) + brighter text -->
    <Style Selector="^:selected /template/ Border#PART_Border">
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowInputBrush}" />
    </Style>
    <Style Selector="^:selected">
      <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    </Style>
  </ControlTheme>
</ResourceDictionary>
