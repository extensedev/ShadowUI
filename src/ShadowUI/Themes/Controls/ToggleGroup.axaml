<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <ControlTheme x:Key="{x:Type shadui:ToggleGroupItem}" TargetType="shadui:ToggleGroupItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowInputBrush}" />
    <Setter Property="BorderThickness" Value="0,1,1,1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="Height" Value="36" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                ClipToBounds="True">
          <Panel>
            <Border Name="PART_HoverFill" Opacity="0"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Background="{DynamicResource ShadowAccentBrush}">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>
            </Border>
            <Border Name="PART_ActiveFill" Opacity="0"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Background="{DynamicResource ShadowPrimaryBrush}">
              <Border.Transitions>
                <Transitions>
                  <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
              </Border.Transitions>
            </Border>
            <ContentPresenter Content="{TemplateBinding Content}"
                              Padding="{TemplateBinding Padding}"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center" />
          </Panel>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- segment rounding: first/last item -->
    <Style Selector="^:nth-child(1)">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6,0,0,6" />
    </Style>
    <Style Selector="^:nth-last-child(1)">
      <Setter Property="CornerRadius" Value="0,6,6,0" />
    </Style>

    <!-- states -->
    <Style Selector="^:pointerover /template/ Border#PART_HoverFill">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:checked /template/ Border#PART_ActiveFill">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="^:checked">
      <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
