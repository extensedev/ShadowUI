<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:Avalonia.Controls.Converters">

  <!-- SplitButton / ToggleSplitButton (shares the SplitButton style key).
       Outline two-segment trigger; ToggleSplitButton:checked turns solid primary. -->
  <converters:CornerRadiusFilterConverter x:Key="ShadowLeftCornerRadiusFilter" Filter="TopLeft, BottomLeft" />
  <converters:CornerRadiusFilterConverter x:Key="ShadowRightCornerRadiusFilter" Filter="TopRight, BottomRight" />

  <!-- Inner segment: paints its own background; outer SplitButton styles drive
       the checked/flyout-open looks through Tag (segments are template children,
       so the outer pseudo-classes cannot reach their pseudo-classes directly). -->
  <ControlTheme x:Key="ShadowSplitButtonSegment" TargetType="Button">
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter Name="PART_ContentPresenter"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          Padding="{TemplateBinding Padding}"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <Style Selector="^[Tag=flyout-open] /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>

    <!-- checked (solid primary): hover dims instead of accent -->
    <Style Selector="^[Tag=checked]:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
      <Setter Property="Opacity" Value="0.9" />
    </Style>
    <Style Selector="^[Tag=checked]:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
      <Setter Property="Opacity" Value="0.9" />
    </Style>
    <Style Selector="^[Tag=checked-flyout-open] /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
      <Setter Property="Opacity" Value="0.9" />
    </Style>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type SplitButton}" TargetType="SplitButton">
    <Setter Property="Background" Value="{DynamicResource ShadowBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="16,7,16,8" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="True" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Grid ColumnDefinitions="*,Auto,Auto">
            <Button Name="PART_PrimaryButton"
                    Grid.Column="0"
                    Theme="{StaticResource ShadowSplitButtonSegment}"
                    Background="{TemplateBinding Background}"
                    Foreground="{TemplateBinding Foreground}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1,1,0,1"
                    CornerRadius="{TemplateBinding CornerRadius, Converter={StaticResource ShadowLeftCornerRadiusFilter}}"
                    Content="{TemplateBinding Content}"
                    ContentTemplate="{TemplateBinding ContentTemplate}"
                    Command="{TemplateBinding Command}"
                    CommandParameter="{TemplateBinding CommandParameter}"
                    Padding="{TemplateBinding Padding}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                    Focusable="False"
                    KeyboardNavigation.IsTabStop="False" />

            <Border Name="SeparatorBorder"
                    Grid.Column="1"
                    Width="1"
                    Background="{TemplateBinding BorderBrush}" />

            <Button Name="PART_SecondaryButton"
                    Grid.Column="2"
                    Theme="{StaticResource ShadowSplitButtonSegment}"
                    Background="{TemplateBinding Background}"
                    Foreground="{TemplateBinding Foreground}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="0,1,1,1"
                    CornerRadius="{TemplateBinding CornerRadius, Converter={StaticResource ShadowRightCornerRadiusFilter}}"
                    MinWidth="34"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    KeyboardNavigation.IsTabStop="False">
              <Path Data="M0,0 L4,4 L8,0"
                    Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                    StrokeThickness="1.5"
                    StrokeLineCap="Round" StrokeJoin="Round"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Button>
          </Grid>
          <Border Name="PART_FocusRing"
                  Margin="{DynamicResource ShadowFocusRingMargin}"
                  BorderThickness="{DynamicResource ShadowFocusRingThickness}"
                  CornerRadius="{DynamicResource ShadowRadiusFocusMd}"
                  BorderBrush="{DynamicResource ShadowFocusRingBrush}"
                  IsVisible="False"
                  IsHitTestVisible="False" />
        </Panel>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:flyout-open /template/ Button">
      <Setter Property="Tag" Value="flyout-open" />
    </Style>

    <!-- ToggleSplitButton checked: solid primary -->
    <Style Selector="^:checked">
      <Setter Property="Background" Value="{DynamicResource ShadowPrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="^:checked /template/ Button">
      <Setter Property="Tag" Value="checked" />
    </Style>
    <Style Selector="^:checked /template/ Border#SeparatorBorder">
      <Setter Property="Background" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
      <Setter Property="Opacity" Value="0.25" />
    </Style>
    <Style Selector="^:checked /template/ Button Path">
      <Setter Property="Stroke" Value="{DynamicResource ShadowPrimaryForegroundBrush}" />
    </Style>
    <Style Selector="^:checked:flyout-open /template/ Button">
      <Setter Property="Tag" Value="checked-flyout-open" />
    </Style>

    <Style Selector="^:focus-visible /template/ Border#PART_FocusRing">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
