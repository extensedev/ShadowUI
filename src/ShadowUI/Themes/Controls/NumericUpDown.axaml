<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- SpinButton: прозрачная кнопка для кнопок-стрелок внутри NumericUpDown -->
  <ControlTheme x:Key="ShadowSpinButton" TargetType="RepeatButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="Background" Duration="0:0:0.10" />
            </Transitions>
          </Border.Transitions>
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            Padding="{TemplateBinding Padding}" />
        </Border>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:pointerover /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource ShadowAccentBrush}" />
    </Style>
    <Style Selector="^:pressed /template/ Border#PART_Border">
      <Setter Property="Opacity" Value="0.75" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.4" />
    </Style>
  </ControlTheme>

  <!-- ShadowButtonSpinner: лэйаут для NumericUpDown (именованный ключ, не глобальный) -->
  <ControlTheme x:Key="ShadowButtonSpinner" TargetType="ButtonSpinner">
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                ClipToBounds="True"
                BoxShadow="{DynamicResource ShadowShadowXs}">
          <Grid ColumnDefinitions="*,Auto">
            <ContentPresenter Grid.Column="0"
                              Content="{TemplateBinding Content}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
            <!-- кнопки ▲▼ справа, разделены тонкой линией от поля ввода -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ShadowInputBrush}"
                    BorderThickness="1,0,0,0"
                    IsVisible="{TemplateBinding ShowButtonSpinner}">
              <Grid RowDefinitions="*,Auto,*">
                <RepeatButton Name="PART_IncreaseButton"
                              Grid.Row="0"
                              Theme="{StaticResource ShadowSpinButton}"
                              CornerRadius="0"
                              Width="24">
                  <Path Data="M0,4 L4,0 L8,4"
                        Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                        StrokeThickness="1.5"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </RepeatButton>
                <Border Grid.Row="1"
                        Height="1"
                        Background="{DynamicResource ShadowInputBrush}" />
                <RepeatButton Name="PART_DecreaseButton"
                              Grid.Row="2"
                              Theme="{StaticResource ShadowSpinButton}"
                              CornerRadius="0"
                              Width="24">
                  <Path Data="M0,0 L4,4 L8,0"
                        Stroke="{DynamicResource ShadowMutedForegroundBrush}"
                        StrokeThickness="1.5"
                        StrokeLineCap="Round" StrokeJoin="Round"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </RepeatButton>
              </Grid>
            </Border>
          </Grid>
        </Border>
        <Border Name="PART_FocusRing"
                Margin="{DynamicResource ShadowFocusRingMargin}"
                BorderThickness="{DynamicResource ShadowFocusRingThickness}"
                CornerRadius="{DynamicResource ShadowRadiusFocusMd}"
                BorderBrush="{DynamicResource ShadowFocusRingBrush}"
                IsVisible="False"
                IsHitTestVisible="False" />
        </Panel>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:focus-within /template/ Border#PART_Border">
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowRingBrush}" />
    </Style>
    <Style Selector="^:focus-within /template/ Border#PART_FocusRing">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>

  <!-- NumericUpDown -->
  <ControlTheme x:Key="{x:Type NumericUpDown}" TargetType="NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource ShadowInputBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowInputBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="AllowSpin" Value="True" />
    <Setter Property="ShowButtonSpinner" Value="True" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Template">
      <ControlTemplate>
        <ButtonSpinner Name="PART_Spinner"
                       Theme="{StaticResource ShadowButtonSpinner}"
                       Background="{TemplateBinding Background}"
                       BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="{TemplateBinding CornerRadius}"
                       AllowSpin="{TemplateBinding AllowSpin}"
                       ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"
                       ButtonSpinnerLocation="{TemplateBinding ButtonSpinnerLocation}">
          <TextBox Name="PART_TextBox"
                   Classes="transparent"
                   Background="Transparent"
                   BorderThickness="0"
                   MinWidth="0"
                   MinHeight="0"
                   Foreground="{TemplateBinding Foreground}"
                   FontSize="{TemplateBinding FontSize}"
                   Padding="{TemplateBinding Padding}"
                   PlaceholderText="{TemplateBinding Watermark}"
                   Text="{TemplateBinding Text, Mode=TwoWay}"
                   IsReadOnly="{TemplateBinding IsReadOnly}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   VerticalContentAlignment="Center" />
        </ButtonSpinner>
      </ControlTemplate>
    </Setter>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
