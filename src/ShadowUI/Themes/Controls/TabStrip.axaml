<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- TabStrip: a TabControl tab list without the content host.
       Same pill-list look as the ShadowUI TabControl. -->
  <ControlTheme x:Key="{x:Type TabStrip}" TargetType="TabStrip">
    <Setter Property="ItemsPanel">
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" Spacing="4" />
      </ItemsPanelTemplate>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_ListBorder"
                Background="{DynamicResource ShadowMutedBrush}"
                CornerRadius="{DynamicResource ShadowRadiusLg}"
                Padding="3" HorizontalAlignment="Left">
          <ItemsPresenter Name="PART_ItemsPresenter"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

  <!-- TabStripItem: visuals match TabItem (active = outline, brighter text) -->
  <ControlTheme x:Key="{x:Type TabStripItem}" TargetType="TabStripItem">
    <Setter Property="Foreground" Value="{DynamicResource ShadowMutedForegroundBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:selected /template/ Border#PART_Border">
      <Setter Property="BorderBrush" Value="{DynamicResource ShadowInputBrush}" />
    </Style>
    <Style Selector="^:selected">
      <Setter Property="Foreground" Value="{DynamicResource ShadowForegroundBrush}" />
    </Style>
    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
