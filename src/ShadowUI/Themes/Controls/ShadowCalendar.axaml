<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shadui="using:ShadowUI">

  <!-- ShadowCalendar: month grid with single and range date selection -->
  <ControlTheme x:Key="{x:Type shadui:ShadowCalendar}" TargetType="shadui:ShadowCalendar">

    <!-- default values -->
    <Setter Property="Padding" Value="16" />
    <Setter Property="Background" Value="{DynamicResource ShadowCardBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShadowBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource ShadowRadiusMd}" />

    <Setter Property="Template">
      <ControlTemplate>
        <!-- Outer border: background, rounding, shadow -->
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">

          <StackPanel Spacing="8">

            <!-- Month navigation: prev/next buttons and the header -->
            <Grid ColumnDefinitions="Auto,*,Auto">

              <!-- Previous month button -->
              <Button Name="PART_PrevButton"
                      Grid.Column="0"
                      Classes="ghost icon"
                      Width="28" Height="28"
                      Padding="0">
                <!-- chevron-left in final pixel coordinates (lucide 24px scaled to 16px) -->
                <Path Data="M 4 8 L 0 4 L 4 0"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" StrokeJoin="Round"
                      Stroke="{DynamicResource ShadowForegroundBrush}"
                      Fill="Transparent" />
              </Button>

              <!-- Month and year header -->
              <TextBlock Name="PART_MonthYearText"
                         Grid.Column="1"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Classes="small"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource ShadowForegroundBrush}" />

              <!-- Next month button -->
              <Button Name="PART_NextButton"
                      Grid.Column="2"
                      Classes="ghost icon"
                      Width="28" Height="28"
                      Padding="0">
                <!-- chevron-right in final pixel coordinates (lucide 24px scaled to 16px) -->
                <Path Data="M 0 8 L 4 4 L 0 0"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" StrokeJoin="Round"
                      Stroke="{DynamicResource ShadowForegroundBrush}"
                      Fill="Transparent" />
              </Button>

            </Grid>

            <!-- Weekday headers: generated from code based on the culture (FirstDayOfWeek) -->
            <UniformGrid Name="PART_WeekdaysGrid" Columns="7" />

            <!-- Day grid: populated from code (BuildDayGrid creates 42 buttons) -->
            <UniformGrid Name="PART_DaysGrid" Columns="7" />

          </StackPanel>
        </Border>
      </ControlTemplate>
    </Setter>

    <!-- Day button styles live in Controls.axaml (global):
         buttons are created from code-behind, and ControlTheme child styles cannot reach them. -->

  </ControlTheme>

</ResourceDictionary>
