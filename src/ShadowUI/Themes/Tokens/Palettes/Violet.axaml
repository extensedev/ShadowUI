<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:Class="ShadowUI.VioletPalette">
  <!-- Violet: colored accent palette - Zinc surfaces + Violet primary (shadcn theme) -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="ShadowBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ShadowForegroundBrush" Color="#09090B" />
      <SolidColorBrush x:Key="ShadowCardBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ShadowCardForegroundBrush" Color="#09090B" />
      <SolidColorBrush x:Key="ShadowPopoverBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ShadowPopoverForegroundBrush" Color="#09090B" />
      <SolidColorBrush x:Key="ShadowPrimaryBrush" Color="#7C3AED" />
      <SolidColorBrush x:Key="ShadowPrimaryHoverBrush" Color="#E67C3AED" />
      <SolidColorBrush x:Key="ShadowPrimaryForegroundBrush" Color="#F8FAFC" />
      <SolidColorBrush x:Key="ShadowSecondaryBrush" Color="#F4F4F5" />
      <SolidColorBrush x:Key="ShadowSecondaryHoverBrush" Color="#CCF4F4F5" />
      <SolidColorBrush x:Key="ShadowSecondaryForegroundBrush" Color="#18181B" />
      <SolidColorBrush x:Key="ShadowMutedBrush" Color="#F4F4F5" />
      <SolidColorBrush x:Key="ShadowMutedForegroundBrush" Color="#71717B" />
      <SolidColorBrush x:Key="ShadowAccentBrush" Color="#F4F4F5" />
      <SolidColorBrush x:Key="ShadowAccentForegroundBrush" Color="#18181B" />
      <SolidColorBrush x:Key="ShadowDestructiveBrush" Color="#E7000B" />
      <SolidColorBrush x:Key="ShadowDestructiveForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowBorderBrush" Color="#E4E4E7" />
      <SolidColorBrush x:Key="ShadowInputBrush" Color="#E4E4E7" />
      <SolidColorBrush x:Key="ShadowRingBrush" Color="#7C3AED" />
      <SolidColorBrush x:Key="ShadowPrimary20Brush" Color="#337C3AED" />
      <SolidColorBrush x:Key="ShadowSwitchThumbBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="ShadowSwitchThumbCheckedBrush" Color="#FFFFFF" />
      <BoxShadows x:Key="ShadowFocusRing">0 0 0 3 #667C3AED</BoxShadows>
      <SolidColorBrush x:Key="ShadowFocusRingBrush" Color="#667C3AED" />
      <SolidColorBrush x:Key="ShadowErrorRingBrush" Color="#33E7000B" />
      <SolidColorBrush x:Key="ShadowInputBackgroundBrush" Color="Transparent" />
      <SolidColorBrush x:Key="ShadowInputHoverBrush" Color="Transparent" />
      <SolidColorBrush x:Key="ShadowDestructiveButtonBrush" Color="#E7000B" />
      <SolidColorBrush x:Key="ShadowDestructiveButtonHoverBrush" Color="#E6E7000B" />
      <BoxShadows x:Key="ShadowErrorRing">0 0 0 3 #33E7000B</BoxShadows>
      <SolidColorBrush x:Key="ShadowChart1Brush" Color="#F54900" />
      <SolidColorBrush x:Key="ShadowChart2Brush" Color="#009689" />
      <SolidColorBrush x:Key="ShadowChart3Brush" Color="#104E64" />
      <SolidColorBrush x:Key="ShadowChart4Brush" Color="#FFB900" />
      <SolidColorBrush x:Key="ShadowChart5Brush" Color="#FE9A00" />
      <SolidColorBrush x:Key="ShadowSidebarBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowSidebarForegroundBrush" Color="#09090B" />
      <SolidColorBrush x:Key="ShadowSidebarAccentBrush" Color="#E2E2E5" />
      <SolidColorBrush x:Key="ShadowSidebarAccentForegroundBrush" Color="#18181B" />
      <SolidColorBrush x:Key="ShadowSidebarPrimaryBrush" Color="#7C3AED" />
      <SolidColorBrush x:Key="ShadowSidebarPrimaryForegroundBrush" Color="#F8FAFC" />
      <SolidColorBrush x:Key="ShadowSidebarBorderBrush" Color="#E4E4E7" />
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="ShadowBackgroundBrush" Color="#09090B" />
      <SolidColorBrush x:Key="ShadowForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowCardBrush" Color="#18181B" />
      <SolidColorBrush x:Key="ShadowCardForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowPopoverBrush" Color="#18181B" />
      <SolidColorBrush x:Key="ShadowPopoverForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowPrimaryBrush" Color="#8B5CF6" />
      <SolidColorBrush x:Key="ShadowPrimaryHoverBrush" Color="#E68B5CF6" />
      <SolidColorBrush x:Key="ShadowPrimaryForegroundBrush" Color="#F8FAFC" />
      <SolidColorBrush x:Key="ShadowSecondaryBrush" Color="#27272A" />
      <SolidColorBrush x:Key="ShadowSecondaryHoverBrush" Color="#CC27272A" />
      <SolidColorBrush x:Key="ShadowSecondaryForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowMutedBrush" Color="#27272A" />
      <SolidColorBrush x:Key="ShadowMutedForegroundBrush" Color="#9F9FA9" />
      <SolidColorBrush x:Key="ShadowAccentBrush" Color="#27272A" />
      <SolidColorBrush x:Key="ShadowAccentForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowDestructiveBrush" Color="#FF6467" />
      <SolidColorBrush x:Key="ShadowDestructiveForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowBorderBrush" Color="#1AFFFFFF" />
      <SolidColorBrush x:Key="ShadowInputBrush" Color="#26FFFFFF" />
      <SolidColorBrush x:Key="ShadowRingBrush" Color="#8B5CF6" />
      <SolidColorBrush x:Key="ShadowPrimary20Brush" Color="#338B5CF6" />
      <SolidColorBrush x:Key="ShadowSwitchThumbBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowSwitchThumbCheckedBrush" Color="#FFFFFF" />
      <BoxShadows x:Key="ShadowFocusRing">0 0 0 3 #668B5CF6</BoxShadows>
      <SolidColorBrush x:Key="ShadowFocusRingBrush" Color="#668B5CF6" />
      <SolidColorBrush x:Key="ShadowErrorRingBrush" Color="#66FF6467" />
      <SolidColorBrush x:Key="ShadowInputBackgroundBrush" Color="#0BFFFFFF" />
      <SolidColorBrush x:Key="ShadowInputHoverBrush" Color="#13FFFFFF" />
      <SolidColorBrush x:Key="ShadowDestructiveButtonBrush" Color="#99FF6467" />
      <SolidColorBrush x:Key="ShadowDestructiveButtonHoverBrush" Color="#8AFF6467" />
      <BoxShadows x:Key="ShadowErrorRing">0 0 0 3 #66FF6467</BoxShadows>
      <SolidColorBrush x:Key="ShadowChart1Brush" Color="#1447E6" />
      <SolidColorBrush x:Key="ShadowChart2Brush" Color="#00BC7D" />
      <SolidColorBrush x:Key="ShadowChart3Brush" Color="#FE9A00" />
      <SolidColorBrush x:Key="ShadowChart4Brush" Color="#AD46FF" />
      <SolidColorBrush x:Key="ShadowChart5Brush" Color="#FF2056" />
      <SolidColorBrush x:Key="ShadowSidebarBrush" Color="#17171A" />
      <SolidColorBrush x:Key="ShadowSidebarForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowSidebarAccentBrush" Color="#2F2F33" />
      <SolidColorBrush x:Key="ShadowSidebarAccentForegroundBrush" Color="#FAFAFA" />
      <SolidColorBrush x:Key="ShadowSidebarPrimaryBrush" Color="#8B5CF6" />
      <SolidColorBrush x:Key="ShadowSidebarPrimaryForegroundBrush" Color="#F8FAFC" />
      <SolidColorBrush x:Key="ShadowSidebarBorderBrush" Color="#27272A" />
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>