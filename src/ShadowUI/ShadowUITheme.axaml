<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShadowUI.ShadowUITheme">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ShadowUI/Themes/Tokens/Radii.axaml" />
        <ResourceInclude Source="avares://ShadowUI/Themes/Tokens/Semantic.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <StyleInclude Source="avares://ShadowUI/Themes/Typography.axaml" />
  <StyleInclude Source="avares://ShadowUI/Themes/Controls.axaml" />
</Styles>
